QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=dobedub_docs
CORPUS_DIR=document/dobedub
EMBEDDING_MODEL=BAAI/bge-m3
CHUNK_SIZE=800
CHUNK_OVERLAP=120
CANDIDATE_K=20
TOP_K=5
USE_RERANK=true
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Cursor SDK (put real key only in .env.local — never commit)
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5

# If you start this repo's docker compose (host port 6335):
# QDRANT_URL=http://localhost:6335
